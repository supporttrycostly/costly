generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  password           String?
  hasFullAccess      Boolean    @default(false)
  entryPurchased     Boolean    @default(false)
  subscriptionStatus String?
  stripeCustomerId   String?    @unique
  stripeSubId        String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  name               String?
  accessType         String     @default("NONE")
  assetSplit         Boolean    @default(false)
  housingScenario    Boolean    @default(false)
  resetToken         String?
  resetTokenExpiry   DateTime?
  retirementImpact   Boolean    @default(false)
  subscriptionId     String?
  vaDisability       Boolean    @default(false)
  canUseSubscription Boolean    @default(false)
  hasAIAdvisor       Boolean    @default(false)
  addons             Addon[]
  payments           Payment[]
  scenarios          Scenario[]
}

model Scenario {
  id               String   @id @default(uuid())
  userId           String
  name             String   @default("Scenario 1")
  userIncome       Float
  spouseIncome     Float
  childrenCount    Int
  custodyPercent   Float
  mortgage         Float    @default(0)
  childcare        Float    @default(0)
  school           Float    @default(0)
  activities       Float    @default(0)
  utilities        Float    @default(0)
  insurance        Float    @default(0)
  otherExpenses    Float    @default(0)
  savings          Float?
  retirement       Float?
  homeEquity       Float?
  netIncome        Float
  monthlySupport   Float
  totalExpenses    Float
  disposableIncome Float
  realityScore     Float
  realityLevel     String
  isAutoGenerated  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  assetSplit       Json?
  housingScenario  Json?
  retirementImpact Json?
  vaDisability     Json?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Addon {
  id        String    @id @default(uuid())
  userId    String
  type      AddonType
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String      @id @default(uuid())
  userId          String
  amount          Int
  currency        String      @default("usd")
  productType     ProductType
  createdAt       DateTime    @default(now())
  stripePaymentId String?
  stripePriceId   String?
  stripeSessionId String      @unique
  user            User        @relation(fields: [userId], references: [id])
}

model StripeEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  type      String
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum AddonType {
  ASSET_SPLIT
  RETIREMENT
  VA_DISABILITY
  HOUSING
}

enum ProductType {
  ENTRY
  CORE
  ADDON
  SUBSCRIPTION
}
